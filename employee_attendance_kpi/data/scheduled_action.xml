<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data noupdate="1">
        
        <!-- Scheduled Action for Daily Record Creation -->
        <record id="ir_cron_create_daily_attendance_kpi" model="ir.cron">
            <field name="name">Create Daily Attendance &amp; KPI Records</field>
            <field name="model_id" ref="model_employee_attendance_kpi"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_daily_records()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=1, minute=0, second=0)"/>
        </record>
        
        <!-- Scheduled Action for Weekly Record Creation -->
        <record id="ir_cron_create_weekly_attendance_kpi" model="ir.cron">
            <field name="name">Create Weekly Attendance &amp; KPI Records</field>
            <field name="model_id" ref="model_employee_attendance_kpi_weekly"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_weekly_records()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=2, minute=0, second=0)"/>
        </record>

        <!-- Scheduled Action for Weekly Business KPI Record Creation -->
        <record id="ir_cron_create_weekly_business_kpi" model="ir.cron">
            <field name="name">Create Weekly Business KPI Records</field>
            <field name="model_id" ref="model_employee_attendance_kpi_weekly_business"/>
            <field name="state">code</field>
            <field name="code">model.cron_create_weekly_business_records()</field>
            <field name="interval_number">1</field>
            <field name="interval_type">days</field>
            <field name="numbercall">-1</field>
            <field name="doall" eval="False"/>
            <field name="active" eval="True"/>
            <field name="nextcall" eval="(DateTime.now() + timedelta(days=1)).replace(hour=3, minute=0, second=0)"/>
        </record>
        
    </data>
    
    <data>
        
        <!-- Server Action for Manual 30-Day Update -->
        <record id="action_update_last_30_days" model="ir.actions.server">
            <field name="name">Update Last 30 Days Records</field>
            <field name="model_id" ref="model_employee_attendance_kpi"/>
            <field name="state">code</field>
            <field name="code">model.update_last_n_days_records(days=30)</field>
        </record>
        
        <!-- Menu for Manual Update -->
        <menuitem id="menu_update_last_30_days"
                  name="Update Last 30 Days"
                  parent="menu_employee_attendance_kpi_root"
                  action="action_update_last_30_days"
                  sequence="25"/>
        
    </data>
</odoo>
