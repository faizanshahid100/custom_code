<?xml version="1.0" encoding="utf-8"?>
<odoo>

    <!-- ══════════════════════════════════════════
         Project Role
    ══════════════════════════════════════════ -->
    <record id="view_ceo_project_role_tree" model="ir.ui.view">
        <field name="name">ceo.project.role.tree</field>
        <field name="model">ceo.project.role</field>
        <field name="arch" type="xml">
            <tree string="Project Roles" editable="bottom">
                <field name="name"/>
                <field name="active"/>
            </tree>
        </field>
    </record>

    <record id="view_ceo_project_role_form" model="ir.ui.view">
        <field name="name">ceo.project.role.form</field>
        <field name="model">ceo.project.role</field>
        <field name="arch" type="xml">
            <form string="Project Role">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="active"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_ceo_project_role" model="ir.actions.act_window">
        <field name="name">Project Roles</field>
        <field name="res_model">ceo.project.role</field>
        <field name="view_mode">tree,form</field>
    </record>

